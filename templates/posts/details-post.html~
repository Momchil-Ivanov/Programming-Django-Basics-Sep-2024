{% load crispy_forms_filters %}
{% load static %}
{% load markdown_extras %}
{% load crispy_forms_tags %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forum Posts</title>
    <link rel="stylesheet" href="{% static 'css/styles.css' %}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&display=swap" rel="stylesheet">
</head>
<body>
    <div class="posts">
        <div class="post">
            <div class="header">
                {% if post.image %}
                    <img src="{{ post.image.url }}" width="50" height="50" class="img-fluid" alt="{{ post.title|capfirst }}">
                {% endif %}
                <h2>{{ post.title|capfirst }}</h2>
                <div class="icons">
                    <a href="{% url 'edit-post' post.pk %}">
                        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor"></svg>
                    </a>
                    <a href="{% url 'delete-post' post.pk %}">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" style="fill:red" viewBox="0 0 24 24" fill="none" stroke="currentColor"></svg>
                    </a>
                </div>
            </div>
            {% if not post.content %}
                <p>{% lorem 3 p %}</p>
            {% else %}
                <p>{{ post.content|markdown }}</p>
            {% endif %}
            <div class="post-meta">
                <span>Posted by {{ post.author|default:"anonymous"}} on {{ post.created_at|date:"Y-M-d" }}</span>
            </div>
        </div>
        <form method="post" class="form-inline">
            {% csrf_token %}
            {{ formset.management_form }}
            <div class="input-group">
                {% for form in formset %}
                    <div class="form-row">
                        {{ form.author | as_crispy_field }}
                        <div class="input-group-append">
                            {{ form.content | as_crispy_field }}
                            <button class="btn btn-primary ml-2" type="submit">Submit</button>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </form>
        <h2>Comments</h2>
        <div class="comments-section">
            {% for comment in post.comments.all %}
                <div class="media mb-3 comment-item">
                    <img scr="https://via.placeholder.com/50" class="mr-3 rounder-circle comment-avatar">
                </div>
                <div class="media-body comment-content">
                    <h5 class="mt-0 comment-author">{{ comment.author }}</h5>
                    <p class="comment-text">{{ comment.content }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
</body>
    <script src='https://unpkg.com/akar-icons-fonts'></script>
</html>
